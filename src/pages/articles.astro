---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="挖洞吧" css={['articles.css']}>
<div class="container" id="mainContainer">
    <!-- 左边广告预留 -->
    <div class="side-space"></div>
    <!-- 主体 -->
    <div class="main">
        <!-- 顶部 -->
        <div class="top-bar">
            <div class="top-left">
                <button class="back-btn" onclick="goBackToHome()">
                    <span class="arrow">←</span>
                    <span data-cn="返回" data-en="Back">返回</span>
                </button>
                <div class="header">
                    <h1 data-cn="挖洞吧" data-en="Hack Zone">挖洞吧</h1>
                    <p data-cn="自己挖 + 市面上大部分漏洞报告，只要小白一直Go就一直更新！" data-en="Self-discovered vulnerabilities + most public reports. As long as GOGO keeps going, updates never stop!">
                        自己挖 + 市面上大部分漏洞报告，只要小白一直Go就一直更新！
                    </p>
                </div>
            </div>
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon">🌐</span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
        <!-- 搜索 -->
        <div class="toolbar">
            <input type="text" id="searchInput" placeholder="搜索漏洞标题..." />
            <button class="search-btn" data-cn="🔍 搜索" data-en="🔍 Search">🔍 搜索</button>
        </div>
        <!-- 文章 3x3 -->
        <div class="article-grid">
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?1"><h3 data-cn="Log2j 存在漏洞风险分析" data-en="Log4j Vulnerability Risk Analysis">Log2j 存在漏洞风险分析</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?2"><h3 data-cn="后台接口存在越权访问漏洞" data-en="Privilege Escalation in Admin API">后台接口存在越权访问漏洞</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?3"><h3 data-cn="支付逻辑存在金额绕过问题" data-en="Payment Logic Bypass Vulnerability">支付逻辑存在金额绕过问题</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?4"><h3 data-cn="接口存在 SQL 注入漏洞" data-en="SQL Injection Vulnerability">接口存在 SQL 注入漏洞</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?5"><h3 data-cn="优惠券接口存在重复领取问题" data-en="Coupon Interface Repeat Claim Issue">优惠券接口存在重复领取问题</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?6"><h3 data-cn="上传接口导致任意文件上传" data-en="Arbitrary File Upload Vulnerability">上传接口导致任意文件上传</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?7"><h3 data-cn="管理员功能存在未授权访问" data-en="Unauthorized Admin Access">管理员功能存在未授权访问</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?8"><h3 data-cn="手机号绑定流程存在缺陷" data-en="Phone Binding Logic Flaw">手机号绑定流程存在缺陷</h3></div>
            <div class="card" onclick="navigateTo('/article')"><img src="https://picsum.photos/300/200?9"><h3 data-cn="XSS 漏洞导致 Cookie 泄露" data-en="XSS Causes Cookie Leakage">XSS 漏洞导致 Cookie 泄露</h3></div>
        </div>
        <!-- 分页 -->
        <div class="pagination">
            <button class="page">&lt;</button>
            <button class="page active">1</button>
            <button class="page">2</button>
            <button class="page">3</button>
            <button class="page">&gt;</button>
        </div>
    </div>
    <div class="side-space"></div>
</div>
</BaseLayout>
